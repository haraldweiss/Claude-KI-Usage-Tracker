{
  "manifest_version": 3,
  "name": "KI Usage Tracker",
  "version": "3.0.0",
  "description": "Dashboard-Viewer für KI/LLM Kosten (Scraping läuft server-seitig)",
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://platform.claude.com/*",
    "https://opencode.ai/*",
    "https://z.ai/*",
    "https://chatgpt.com/*",
    "https://platform.openai.com/*",
    "https://wolfinisoftware.de/*",
    "https://*.wolfinisoftware.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KI Usage Tracker"
  }
}
