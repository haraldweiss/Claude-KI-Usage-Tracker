# Backend Environment Configuration
# Copy this file to .env in the backend directory

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_PATH=./database.sqlite

# Logging
LOG_LEVEL=info

# Pricing Service
ANTHROPIC_API_KEY=your-key-here
PRICING_UPDATE_CRON=0 2 * * *

# Encryption key for provider service tokens (32 hex chars, used by AES-GCM)
SECRETS_KEY=your-32-hex-char-key

# Catalog LLM endpoints (model recommendation HF metadata enrichment)
CATALOG_LLM_URL=
CATALOG_LLM_TOKEN=
CATALOG_LLM_FALLBACK_ANTHROPIC_KEY=

# HuggingFace API token (for catalog model metadata)
HF_TOKEN=

# Magic-link mail (SMTP)
MAIL_FROM=noreply@wolfinisoftware.de
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.your-host.com
SMTP_PORT=587

# Verify URL (override for dev)
VERIFY_BASE_URL=http://localhost:3001/api/auth/verify

# Cookie path (override for sub-path deployments)
COOKIE_PATH=/
