<?xml version="1.0" encoding="UTF-8"?>
<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">
  <Description about="urn:mozilla:install-manifest">
    <em:id>ki-usage-tracker@wolfinisoftware.de</em:id>
    <em:name>KI Usage Tracker</em:name>
    <em:version>3.2.1</em:version>
    <em:description>Dashboard-Viewer für KI/LLM Kosten (Cookie-Export + Backend-Anzeige)</em:description>
    <em:creator>Harald Weiss</em:creator>
    <em:type>2</em:type>
    <em:bootstrap>true</em:bootstrap>
    <em:hasEmbeddedWebExtension>false</em:hasEmbeddedWebExtension>

    <!-- Pale Moon / Firefox / UXP-based browsers -->
    <em:targetApplication>
      <Description>
        <em:id>{ec8030f7-c20a-464f-9b0e-13a3a9e97384}</em:id>
        <em:minVersion>28.0</em:minVersion>
        <em:maxVersion>33.*</em:maxVersion>
      </Description>
    </em:targetApplication>
  </Description>
</RDF>
