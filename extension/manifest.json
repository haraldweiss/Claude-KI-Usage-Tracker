{
  "manifest_version": 3,
  "name": "Claude Usage Tracker",
  "version": "2.0.0",
  "description": "Track your Claude.ai usage in real-time",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://platform.claude.com/*",
    "https://opencode.ai/*",
    "https://z.ai/*",
    "https://chatgpt.com/*",
    "https://platform.openai.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://wolfinisoftware.de/*",
    "https://*.wolfinisoftware.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage Tracker"
  }
}
