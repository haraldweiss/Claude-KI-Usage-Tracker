{
  "manifest_version": 3,
  "name": "Claude Usage Tracker",
  "version": "1.0.0",
  "description": "Track your Claude.ai usage in real-time",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://api.claude.ai/*",
    "https://console.anthropic.com/*",
    "https://platform.claude.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://wolfinisoftware.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage Tracker"
  }
}
