# KI Usage Tracker - Environment Configuration
# Copy this file to .env and adjust values for your environment

# Backend
BACKEND_PORT=3000
DATABASE_PATH=./backend/database.sqlite
NODE_ENV=development

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# Pricing Service
ANTHROPIC_API_KEY=your-key-here
PRICING_UPDATE_CRON=0 2 * * *

# Logging
LOG_LEVEL=debug

# AES-256-GCM key for encrypting per-user secrets (ai-provider-service tokens).
# Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key means users must re-enter their service tokens.
SECRETS_KEY=
